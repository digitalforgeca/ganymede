{
  "chalice-telemetry": {
    "enabled": true,
    "PreInvocation": [
      {
        "type": "command",
        "command": "python3 ~/.gemini/config/plugins/chalice/scripts/broadcast.py"
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.gemini/config/plugins/chalice/scripts/broadcast.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.gemini/config/plugins/chalice/scripts/broadcast.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "python3 ~/.gemini/config/plugins/chalice/scripts/broadcast.py"
      }
    ]
  }
}
